<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".logic.AddNewCardActivity">

    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bubble_shape"
        android:alpha="0.12"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:translationX="80dp"
        android:translationY="-40dp"/>

    <View
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:background="@drawable/bubble_shape"
        android:alpha="0.10"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:translationX="-70dp"
        android:translationY="90dp"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="48dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/backButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/icon_circle_bg"
                    android:padding="12dp"
                    android:src="@drawable/ic_back_arrow"
                    android:contentDescription="Back"/>



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add New Card"
                    android:textColor="#4A5AE8"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Enter payment details"
                android:textColor="#1E1E1E"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Your card information will be used for future reservations."
                android:textColor="#777777"
                android:textSize="15sp"/>

            <!-- Card preview -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPreview"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginTop="22dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="5dp"
                app:cardBackgroundColor="#4A5AE8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_payment_chip"
                        android:contentDescription="Card Chip"/>

                    <TextView
                        android:id="@+id/cardPreviewNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="28dp"
                        android:text="**** **** **** 2481"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Card Holder"
                                android:textColor="#DCE2FF"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/cardPreviewName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Sarah Johnson"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Expires"
                                android:textColor="#DCE2FF"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/cardPreviewExpiry"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="08/28"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Card Information"
                android:textColor="#101A63"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/cardholderNameEditText"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_field"
                android:hint="Cardholder Name"
                android:padding="14dp"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"/>

            <EditText
                android:id="@+id/cardNumberEditText"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_field"
                android:hint="Card Number"
                android:inputType="number"
                android:maxLength="19"
                android:padding="14dp"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/expiryDateEditText"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/input_field"
                    android:hint="MM/YY"
                    android:inputType="number"
                    android:maxLength="5"
                    android:padding="14dp"
                    android:textColor="#1E1E1E"
                    android:textColorHint="#999999"/>

                <EditText
                    android:id="@+id/cvvEditText"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/input_field"
                    android:hint="CVV"
                    android:inputType="numberPassword"
                    android:maxLength="4"
                    android:padding="14dp"
                    android:textColor="#1E1E1E"
                    android:textColorHint="#999999"/>
            </LinearLayout>

            <EditText
                android:id="@+id/postalCodeEditText"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_field"
                android:hint="Postal / ZIP Code"
                android:padding="14dp"
                android:textColor="#1E1E1E"
                android:textColorHint="#999999"/>

            <CheckBox
                android:id="@+id/setDefaultCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Set as default payment method"
                android:textColor="#4A5AE8"
                android:textSize="14sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveCardButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="28dp"
                android:text="Save Card"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="#4A5AE8"
                app:cornerRadius="18dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancelButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Cancel"
                android:textColor="#4A5AE8"
                android:textStyle="bold"
                android:textSize="16sp"
                android:backgroundTint="#EEF1FF"
                app:cornerRadius="18dp"/>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>